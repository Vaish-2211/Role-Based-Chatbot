# ── LLM Provider ──────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Vector Database ────────────────────────────────────────────────────────────
# Docker local: http://localhost:6333  |  Qdrant Cloud: https://xyz.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finsolve_docs

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-very-long-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LangSmith Monitoring (optional but recommended) ───────────────────────────
# Get key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finsolve-rag

# ── App ────────────────────────────────────────────────────────────────────────
# URL the Streamlit frontend uses to reach the FastAPI backend
BACKEND_URL=http://localhost:8000
LOG_LEVEL=INFO
